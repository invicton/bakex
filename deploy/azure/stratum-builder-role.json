{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Creates a Stratum builder custom role and assigns it to an existing Microsoft Entra service principal at a Stratum resource-group scope."
  },
  "parameters": {
    "principalObjectId": {
      "type": "string",
      "metadata": {
        "description": "Object ID of the existing service principal Stratum will use."
      }
    },
    "principalType": {
      "type": "string",
      "defaultValue": "ServicePrincipal",
      "allowedValues": [
        "ServicePrincipal",
        "User",
        "Group",
        "ManagedIdentity"
      ],
      "metadata": {
        "description": "Azure RBAC principal type for principalObjectId."
      }
    },
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "stratum-builds",
      "metadata": {
        "description": "Resource group where Stratum temporary build VMs and managed images will be created."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "eastus",
      "metadata": {
        "description": "Azure region for the resource group and default Stratum configuration."
      }
    },
    "roleNamePrefix": {
      "type": "string",
      "defaultValue": "Stratum",
      "metadata": {
        "description": "Prefix for the custom role name."
      }
    }
  },
  "variables": {
    "roleDefinitionGuid": "[guid(subscription().subscriptionId, parameters('roleNamePrefix'), 'builder-role')]",
    "roleAssignmentGuid": "[guid(subscription().subscriptionId, parameters('resourceGroupName'), parameters('principalObjectId'), variables('roleDefinitionGuid'))]",
    "roleName": "[format('{0} Builder', parameters('roleNamePrefix'))]",
    "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleDefinitionGuid'))]",
    "resourceGroupScope": "[format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2022-09-01",
      "name": "[parameters('resourceGroupName')]",
      "location": "[parameters('location')]",
      "tags": {
        "managed-by": "stratum"
      }
    },
    {
      "type": "Microsoft.Authorization/roleDefinitions",
      "apiVersion": "2022-04-01",
      "name": "[variables('roleDefinitionGuid')]",
      "properties": {
        "roleName": "[variables('roleName')]",
        "description": "Least-privilege Stratum builder role for temporary Azure VMs, Run Command hardening, and managed image capture.",
        "type": "CustomRole",
        "permissions": [
          {
            "actions": [
              "Microsoft.Resources/subscriptions/resourceGroups/read",
              "Microsoft.Resources/resources/read",
              "Microsoft.Compute/images/read",
              "Microsoft.Compute/images/write",
              "Microsoft.Compute/images/delete",
              "Microsoft.Compute/disks/read",
              "Microsoft.Compute/disks/write",
              "Microsoft.Compute/disks/delete",
              "Microsoft.Compute/snapshots/read",
              "Microsoft.Compute/virtualMachines/read",
              "Microsoft.Compute/virtualMachines/write",
              "Microsoft.Compute/virtualMachines/delete",
              "Microsoft.Compute/virtualMachines/instanceView/read",
              "Microsoft.Compute/virtualMachines/deallocate/action",
              "Microsoft.Compute/virtualMachines/generalize/action",
              "Microsoft.Compute/virtualMachines/runCommand/action",
              "Microsoft.Compute/locations/runCommands/read",
              "Microsoft.Network/networkInterfaces/read",
              "Microsoft.Network/networkInterfaces/write",
              "Microsoft.Network/networkInterfaces/delete",
              "Microsoft.Network/networkInterfaces/join/action",
              "Microsoft.Network/networkSecurityGroups/read",
              "Microsoft.Network/virtualNetworks/read",
              "Microsoft.Network/virtualNetworks/subnets/read",
              "Microsoft.Network/virtualNetworks/subnets/join/action"
            ],
            "notActions": [],
            "dataActions": [],
            "notDataActions": []
          }
        ],
        "assignableScopes": [
          "[subscription().id]"
        ]
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[variables('roleAssignmentGuid')]",
      "scope": "[format('Microsoft.Resources/resourceGroups/{0}', parameters('resourceGroupName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/resourceGroups', parameters('resourceGroupName'))]",
        "[variables('roleDefinitionId')]"
      ],
      "properties": {
        "roleDefinitionId": "[variables('roleDefinitionId')]",
        "principalId": "[parameters('principalObjectId')]",
        "principalType": "[parameters('principalType')]"
      }
    }
  ],
  "outputs": {
    "SubscriptionId": {
      "type": "string",
      "value": "[subscription().subscriptionId]"
    },
    "ResourceGroupName": {
      "type": "string",
      "value": "[parameters('resourceGroupName')]"
    },
    "Location": {
      "type": "string",
      "value": "[parameters('location')]"
    },
    "RoleDefinitionId": {
      "type": "string",
      "value": "[variables('roleDefinitionId')]"
    },
    "RoleAssignmentScope": {
      "type": "string",
      "value": "[variables('resourceGroupScope')]"
    }
  }
}
